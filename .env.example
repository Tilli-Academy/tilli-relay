# PostgreSQL connection
DATABASE_URL="postgresql://relay:relay@localhost:5433/relay"

# Redis connection (sessions)
REDIS_URL="redis://localhost:6379"

# JWT secret for auth (change in production)
JWT_SECRET="change-me-in-production"

# Encryption key for secret environment variables (generate with: openssl rand -hex 32)
# Leave empty to disable encryption (not recommended for production)
RELAY_ENCRYPTION_KEY=""
